<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogSongOptionsRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtOptionsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/song_options"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtOptionsSongTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/song_title_placeholder"
        android:textColor="#BDBDBD"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtOptionsSongArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/artist_placeholder"
        android:textColor="#858585"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/actionReportSong"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/report_icon"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtReportSongAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/report_song"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionToggleComments"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/comment_icon"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtToggleCommentsAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/lock_comments"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionDeleteSong"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="@string/delete_icon"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtDeleteSongAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/delete_song"
            android:textColor="#FF6B6B"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>