<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adminDashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/adminDashboardTopBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/back"
                android:padding="10dp"
                android:src="@drawable/ic_return"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDashboardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_dashboard"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDashboardSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/admin_dashboard_subtitle"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- OVERVIEW CARD -->
        <LinearLayout
            android:id="@+id/communityOverviewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_admin_gradient_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/txtCommunityTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/community_standards"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCommunityDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/community_standards_description"
                android:textColor="#E0E0E0"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnOpenModeration"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/orange"
                android:text="@string/open_moderation_queue"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOpenReports"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#424242"
                android:text="@string/open_reports"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ADMIN NOTIFICATION CARD -->
        <LinearLayout
            android:id="@+id/adminNotificationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_admin_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtAdminNotificationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_notifications"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminNotificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/no_admin_notifications"
                android:textColor="#D0D0D0"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- STATS -->
        <LinearLayout
            android:id="@+id/statsRowOne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardPending"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/txtPendingValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtPendingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/pending"
                    android:textColor="#AFAFAF"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardApproved"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/txtApprovedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtApprovedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/approved"
                    android:textColor="#AFAFAF"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/statsRowTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardRejected"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/txtRejectedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtRejectedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/rejected"
                    android:textColor="#AFAFAF"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardHidden"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/txtHiddenValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtHiddenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/hidden"
                    android:textColor="#AFAFAF"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- COMMUNITY STANDARD HEADER -->
        <LinearLayout
            android:id="@+id/communityStandardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtRulesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/community_rules"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRulesSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/community_rules_subtitle"
                android:textColor="#9E9E9E"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- RULE LIST -->
        <LinearLayout
            android:id="@+id/communityRulesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <include
                android:id="@+id/ruleOffensiveContent"
                layout="@layout/item_community_standard" />

            <include
                android:id="@+id/ruleViolence"
                layout="@layout/item_community_standard" />

            <include
                android:id="@+id/ruleCopyright"
                layout="@layout/item_community_standard" />

            <include
                android:id="@+id/ruleSpam"
                layout="@layout/item_community_standard" />

            <include
                android:id="@+id/ruleInappropriateImage"
                layout="@layout/item_community_standard" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>