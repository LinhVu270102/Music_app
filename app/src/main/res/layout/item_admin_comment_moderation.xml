<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/adminCommentItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_admin_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/txtCommentUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/profile"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtCommentSong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/comment_song_placeholder"
        android:textColor="#FFB74D"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/txtCommentContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/comment"
        android:textColor="#D0D0D0"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnHideComment"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#B71C1C"
        android:text="@string/hide_comment"
        android:textAllCaps="false"
        android:textColor="@color/white" />

</LinearLayout>