<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adminRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="16dp">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/adminTopBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_return"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAdminTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/content_moderation"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/content_moderation_subtitle"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="@string/refresh"
            android:padding="10dp"
            android:src="@drawable/ic_refresh"
            app:tint="@color/white" />

    </LinearLayout>

    <!-- OVERVIEW CARD -->
    <LinearLayout
        android:id="@+id/overviewCard"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_admin_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtOverviewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/moderation_queue"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOverviewSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/moderation_queue_subtitle"
                android:textColor="#A6A6A6"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtSongCount"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_count_circle"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- STATUS FILTERS -->
    <HorizontalScrollView
        android:id="@+id/statusScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/statusContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPending"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_admin_status_button"
                android:minWidth="96dp"
                android:text="@string/pending"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnApproved"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_admin_status_button"
                android:minWidth="96dp"
                android:text="@string/approved"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRejected"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_admin_status_button"
                android:minWidth="96dp"
                android:text="@string/rejected"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnHidden"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/bg_admin_status_button"
                android:minWidth="96dp"
                android:text="@string/hidden"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- CULTURAL STANDARD CARD -->
    <LinearLayout
        android:id="@+id/culturalStandardCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_admin_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtCulturalStandardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cultural_standard"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCulturalStandardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/cultural_standard_description"
            android:textColor="#A6A6A6"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- LOADING -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/no_songs_in_this_status"
        android:textColor="#888888"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- SONG LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAdminSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>