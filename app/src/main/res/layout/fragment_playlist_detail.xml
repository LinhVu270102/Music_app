<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playlistDetailFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_return" />

        <TextView
            android:id="@+id/tvPlaylistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/playlists"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/playlistHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp">

        <ImageView
            android:id="@+id/imgPlaylistCover"
            android:layout_width="116dp"
            android:layout_height="116dp"
            android:background="@drawable/bg_search_box"
            android:contentDescription="@string/playlist_cover"
            android:scaleType="centerCrop"
            android:src="@drawable/music_orange" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlaylistSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlist_detail_subtitle"
                android:textColor="@color/gray_light"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSongCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/playlist_song_count_placeholder"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnTogglePlaylistLike"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/like_playlist"
                android:padding="10dp"
                android:src="@drawable/ic_like"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnPlayAll"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/orange"
                android:text="@string/play_all"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAddCurrentSong"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/gray"
                android:text="@string/add_current_song"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="@string/no_songs_in_playlist"
        android:textColor="@color/gray_light"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="0dp"
        android:paddingBottom="120dp" />

</LinearLayout>
