<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp">

    <!-- SEARCH BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- SEARCH BOX -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/search"
                android:src="@drawable/ic_search"
                app:tint="#BDBDBD" />

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:textSize="18sp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/cancel"
            android:padding="10dp"
            android:src="@drawable/ic_cancel"
            android:visibility="gone"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- TABS -->
    <HorizontalScrollView
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="18dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabAll"
                style="@style/SearchTabSelected"
                android:text="@string/all" />

            <TextView
                android:id="@+id/tabTracks"
                style="@style/SearchTab"
                android:text="@string/tracks" />

            <TextView
                android:id="@+id/tabProfiles"
                style="@style/SearchTab"
                android:text="@string/profiles" />

            <TextView
                android:id="@+id/tabPlaylists"
                style="@style/SearchTab"
                android:text="@string/playlists" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvSearchSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/recently_searched"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- RESULT LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="120dp" />

</LinearLayout>