<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Window settings -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.Music_app" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Window settings -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="SoundCloudSearchView" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:textColor">#FFFFFF</item>
        <item name="queryBackground">@android:color/transparent</item>
        <item name="android:textColorHint">@android:color/darker_gray</item>
    </style>
    <style name="GenreChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">#DDDDDD</item>
        <item name="android:textSize">15sp</item>
        <item name="android:background">@drawable/bg_genre_chip</item>
    </style>

    <style name="GenreChipSelected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">#DFA8FF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_genre_chip_selected</item>
    </style>

    <style name="SearchTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">#AFAFAF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SearchTabSelected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
