# SoundCloud server environment example
# Copy this file to soundcloud-server/.env and replace values with your own credentials.
# Never commit the real .env file.

PORT=3000

SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# Optional: Firebase Admin SDK service account path for local scripts only.
# Do not commit the real serviceAccountKey.json file.
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
