rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId && isImageUpload();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /covers/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId && isImageUpload();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /songs/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId &&
        request.resource.size < 25 * 1024 * 1024 &&
        request.resource.contentType.matches('audio/.*');
      allow delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
